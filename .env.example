# SenSimul Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# WEATHER API (OpenWeatherMap)
# =============================================================================
# Weather API key for live weather data (get free key at openweathermap.org)
# Required only if weather.mode is set to "openweathermap"
SENSIMUL_WEATHER_API_KEY=

# =============================================================================
# MQTT BROKER
# =============================================================================
# MQTT broker URL (e.g., tcp://localhost:1883, tcp://mqtt:1883)
SENSIMUL_MQTT_BROKER_URL=tcp://localhost:1883

# MQTT client identifier (leave empty for auto-generated)
SENSIMUL_MQTT_CLIENT_ID=

# MQTT QoS level (0, 1, or 2)
SENSIMUL_MQTT_QOS=1

# MQTT over WebSocket listener account.
# Docker Compose opens TCP MQTT on 1883 and authenticated MQTT WebSocket on 9001.
# Set real values in .env. Do not commit production credentials.
MQTT_WS_USERNAME=
MQTT_WS_PASSWORD=

# =============================================================================
# APPLICATION MODE
# =============================================================================
# Run mode: dev, test, or prodlike
SENSIMUL_MODE=dev

# SQLite database path
SENSIMUL_SQLITE_PATH=data/sensimul.db

# Tick interval (e.g., 1s, 500ms)
SENSIMUL_TICK_INTERVAL=1s

# =============================================================================
# WEB SERVER
# =============================================================================
# Web server listen address
SENSIMUL_WEB_LISTEN_ADDR=:8080

# Time before sensor data is marked stale
SENSIMUL_WEB_STALE_AFTER=10s

# SSE buffer size
SENSIMUL_WEB_SSE_BUFFER=256

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error
SENSIMUL_LOGGING_LEVEL=info

# Log format: json or console
SENSIMUL_LOGGING_FORMAT=json
